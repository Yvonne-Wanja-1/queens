# Keep repository-level ignores in the root .gitignore.
# This file is intentionally minimal to avoid duplicate ignore rules.

############################################
# Node.js Backend
############################################

# Dependencies
node_modules/

# Environment variables
.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################################
# Flutter / Dart
############################################

.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.pub-cache/
build/
coverage/

############################################
# Android
############################################

android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/

############################################
# iOS
############################################

ios/Flutter/.last_build_id

############################################
# IDEs
############################################

.vscode/
.idea/
*.iml

############################################
# Operating System Files
############################################

.DS_Store
Thumbs.db

############################################
# Miscellaneous
############################################

*.class
*.pyc
*.swp
.history
.svn/
.swiftpm/
.build/
.buildlog/
migrate_working_dir/